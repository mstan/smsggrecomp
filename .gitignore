*.sms
*.gg
*.sg
*.bin
*.sav
*.srm
*.state

# Per-run / generated artifacts
**/__pycache__/
_diag/
*.log
*.err
dispatch_misses.log
tests/last_run/
**/*.unresolved_jumptables.log
*.png
*.wav

# Internal working notes — never commit
LICENSING.md

# README showcase images (intentionally tracked despite *.png above)
!screenshots/*.png
